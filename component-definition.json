{
  "groups": [
    {
      "title": "Default Content",
      "id": "default",
      "components": [
        {
          "title": "Text",
          "id": "text",
          "model": "text",
          "plugins": {
            "da": {
              "name": "text",
              "type": "text"
            }
          }
        },
        {
          "title": "Image",
          "id": "image",
          "model": "image",
          "plugins": {
            "da": {
              "name": "image",
              "type": "image",
              "fields": [
                {
                  "name": "image",
                  "selector": "img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "img[alt]"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "title": "Sections",
      "id": "sections",
      "components": [
        {
          "title": "Section",
          "id": "section",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>"
            }
          },
          "filter": "section",
          "model": "section"
        }
      ]
    },
    {
      "title": "Blocks",
      "id": "blocks",
      "components": [
        {
          "title": "Accordion",
          "id": "accordion",
          "model": "accordion",
          "filter": "accordion",
          "plugins": {
            "da": {
              "name": "accordion",
              "rows": 1,
              "columns": 2
            }
          }
        },
        {
          "title": "Accordion Item",
          "id": "accordion-item",
          "model": "accordion-item",
          "plugins": {
            "da": {
              "name": "accordion-item",
              "rows": 2,
              "columns": 0,
              "fields": [
                {
                  "name": "summary",
                  "selector": "div:nth-child(1)"
                },
                {
                  "name": "text",
                  "selector": "div:nth-child(2)"
                }
              ]
            }
          }
        },
        {
          "title": "Alert",
          "id": "alert",
          "model": "alert",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"alert\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"lazy\" src=\"\" alt=\"\"></picture></div><div><p><strong>YOU DECIDE:</strong> Limited-Time $80 Instant Savings<sup>†</sup> <em><strong>OR</strong></em> Promotional Financing.*</p><p class=\"button-container\"><a class=\"button\" href=\"#\">Learn more.</a></p></div></div></div>",
              "fields": [
                {
                  "name": "iconImage",
                  "selector": "div>div:nth-child(1)>picture>img[src]"
                },
                {
                  "name": "iconAlt",
                  "selector": "div>div:nth-child(1)>picture>img[alt]"
                },
                {
                  "name": "message",
                  "selector": "div>div:nth-child(2)>p:nth-child(1)"
                },
                {
                  "name": "ctaUrl",
                  "selector": "div>div:nth-child(2)>p.button-container>a[href]"
                },
                {
                  "name": "ctaText",
                  "selector": "div>div:nth-child(2)>p.button-container>a"
                }
              ]
            }
          }
        },
        {
          "title": "Cards",
          "id": "cards",
          "model": "cards",
          "filter": "cards",
          "plugins": {
            "da": {
              "rows": 1,
              "columns": 2
            }
          }
        },
        {
          "title": "Card",
          "id": "card",
          "model": "card",
          "plugins": {
            "da": {
              "rows": 1,
              "columns": 2,
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1)>picture>img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:nth-child(1)>picture>img[alt]"
                },
                {
                  "name": "text",
                  "selector": "div:nth-child(2)"
                }
              ]
            }
          }
        },
        {
          "title": "Carousel",
          "id": "carousel",
          "model": "carousel",
          "filter": "carousel",
          "plugins": {
            "da": {
              "rows": 1,
              "columns": 1
            }
          }
        },
        {
          "title": "Carousel Slide",
          "id": "carousel-item",
          "model": "carousel-item",
          "plugins": {
            "da": {
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "backgroundImage",
                  "selector": "div:nth-child(1)>picture>img[src]"
                },
                {
                  "name": "backgroundImageAlt",
                  "selector": "div:nth-child(1)>picture>img[alt]"
                },
                {
                  "name": "text",
                  "selector": "div:nth-child(2)"
                }
              ]
            }
          }
        },
        {
          "title": "Columns",
          "id": "columns",
          "model": "columns",
          "filter": "columns",
          "plugins": {
            "da": {
              "name": "columns",
              "rows": 1,
              "columns": 2,
              "behaviour": "columns"
            }
          }
        },
        {
          "title": "Columns Row",
          "id": "columns-row",
          "model": "columns-row",
          "filter": "columns-row",
          "plugins": {
            "da": {
              "name": "columns-row",
              "behaviour": "columns-row"
            }
          }
        },
        {
          "title": "Columns Cell",
          "id": "columns-cell",
          "model": "columns-cell",
          "filter": "columns-cell",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>",
              "behaviour": "columns-cell"
            }
          }
        },
        {
          "title": "Fragment",
          "id": "fragment",
          "model": "fragment",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"fragment\"><div><div><p><a href=\"\">Fragment URL</a></p></div></div></div>",
              "fields": [
                {
                  "name": "url",
                  "selector": "div>div>p>a[href]"
                },
                {
                  "name": "urlText",
                  "selector": "div>div>p>a"
                }
              ]
            }
          }
        },
        {
          "title": "Hero promo (black thin)",
          "id": "hero-promo-black-thin",
          "model": "hero-promo-black-thin",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"hero-promo black-thin\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"lazy\" src=\"\" alt=\"\"></picture></div><div><p><strong>YOU DECIDE:</strong> Limited-Time $80 Instant Savings<sup>†</sup> <em><strong>OR</strong></em> Promotional Financing.*</p><p class=\"button-container\"><a class=\"button\" href=\"#\">Learn more.</a></p></div></div></div>",
              "fields": [
                {
                  "name": "iconImage",
                  "selector": "div>div:nth-child(1)>picture>img[src]"
                },
                {
                  "name": "iconAlt",
                  "selector": "div>div:nth-child(1)>picture>img[alt]"
                },
                {
                  "name": "promo",
                  "selector": "div>div:nth-child(2)>p:nth-child(1)"
                },
                {
                  "name": "ctaUrl",
                  "selector": "div>div:nth-child(2)>p.button-container>a[href]"
                },
                {
                  "name": "ctaText",
                  "selector": "div>div:nth-child(2)>p.button-container>a"
                }
              ]
            }
          }
        },
        {
          "title": "Hero promo (brand split)",
          "id": "hero-promo-brand-split",
          "model": "hero-promo-brand-split",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"hero-promo brand-split\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"lazy\" src=\"\" alt=\"\"></picture><h2>Brand Tires</h2><p>Established in 1889, this brand ranks among the world's most respected tire manufacturers. They pride themselves on innovation, driver satisfaction, and all-around excellence.</p><p class=\"button-container\"><a class=\"button primary\" href=\"#\">SHOP ALL BRAND TIRES</a></p><p><a href=\"#\">List of available tire products</a></p></div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"lazy\" src=\"\" alt=\"\"></picture></div></div></div>",
              "fields": [
                {
                  "name": "watermarkImage",
                  "selector": "div>div:nth-child(1)>picture:nth-of-type(1)>img[src]"
                },
                {
                  "name": "watermarkAlt",
                  "selector": "div>div:nth-child(1)>picture:nth-of-type(1)>img[alt]"
                },
                {
                  "name": "title",
                  "selector": "div>div:nth-child(1)>h2"
                },
                {
                  "name": "body",
                  "selector": "div>div:nth-child(1)>p:nth-of-type(1)"
                },
                {
                  "name": "primaryCtaUrl",
                  "selector": "div>div:nth-child(1)>p.button-container>a[href]"
                },
                {
                  "name": "primaryCtaText",
                  "selector": "div>div:nth-child(1)>p.button-container>a"
                },
                {
                  "name": "secondaryUrl",
                  "selector": "div>div:nth-child(1)>p:last-child>a[href]"
                },
                {
                  "name": "secondaryText",
                  "selector": "div>div:nth-child(1)>p:last-child>a"
                },
                {
                  "name": "heroImage",
                  "selector": "div>div:nth-child(2)>picture>img[src]"
                },
                {
                  "name": "heroAlt",
                  "selector": "div>div:nth-child(2)>picture>img[alt]"
                }
              ]
            }
          }
        },
        {
          "title": "Hero",
          "id": "hero",
          "model": "hero",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"hero\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"lazy\"></picture><h1></h1></div></div></div>",
              "fields": [
                {
                  "name": "image",
                  "selector": "div>div>picture>img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div>div>picture>img[alt]"
                },
                {
                  "name": "text",
                  "selector": "div>div>h1"
                }
              ]
            }
          }
        },
        {
          "title": "Quote",
          "id": "quote",
          "model": "quote",
          "plugins": {
            "da": {
              "name": "quote",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "quote",
                  "selector": "div:nth-child(1)>div"
                },
                {
                  "name": "author",
                  "selector": "div:nth-child(2)>div"
                }
              ]
            }
          }
        },
        {
          "title": "Search",
          "id": "search",
          "model": "search",
          "plugins": {
            "da": {
              "name": "search",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "searchUrl",
                  "selector": "div>div>p>a[href]"
                },
                {
                  "name": "searchUrlText",
                  "selector": "div>div>p>a"
                }
              ]
            }
          }
        },
        {
          "title": "Table",
          "id": "table",
          "model": "table",
          "filter": "table",
          "plugins": {
            "da": {
              "name": "table",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "table",
                  "selector": "div>div"
                }
              ]
            }
          }
        },
        {
          "title": "Tabs",
          "id": "tabs",
          "model": "tabs",
          "filter": "tabs",
          "plugins": {
            "da": {
              "columns": 1,
              "rows": 2
            }
          }
        },
        {
          "title": "Tabs Item",
          "id": "tabs-item",
          "model": "tabs-item",
          "plugins": {
            "da": {
              "columns": 0,
              "rows": 2,
              "fields": [
                {
                  "name": "name",
                  "selector": "div:nth-child(1)"
                },
                {
                  "name": "content",
                  "selector": "div:nth-child(2)"
                }
              ]
            }
          }
        },
        {
          "title": "Tire Search",
          "id": "tire-search",
          "model": "tire-search",
          "plugins": {
            "da": {
              "name": "tire-search",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "indexUrl",
                  "selector": "div>div>p>a[href]"
                },
                {
                  "name": "indexUrlText",
                  "selector": "div>div>p>a"
                }
              ]
            }
          }
        },
        {
          "title": "Video",
          "id": "video",
          "model": "video",
          "plugins": {
            "da": {
              "name": "video",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "videoUrl",
                  "selector": "div>div>p>a[href]"
                },
                {
                  "name": "videoUrlText",
                  "selector": "div>div>p>a"
                },
                {
                  "name": "posterImage",
                  "selector": "div>div>picture>img[src]"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}